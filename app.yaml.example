# Intentionally incomplete App Engine template.
# Students must adapt runtime settings, entrypoint, env vars,
# and service integration for their own deployment.

runtime: python311

entrypoint: gunicorn -w 2 -k uvicorn.workers.UvicornWorker main:app

env_variables:
  # TODO: Fill these values for your project setup.
  GOOGLE_CLOUD_PROJECT: "REPLACE_ME"
  DB_HOST: "REPLACE_ME"
  DB_NAME: "REPLACE_ME"
  DB_USER: "REPLACE_ME"
  DB_PASSWORD: "REPLACE_ME"
  GCS_BUCKET_NAME: "REPLACE_ME"
  FIRESTORE_COLLECTION_AUDIT_EVENTS: "REPLACE_ME"
